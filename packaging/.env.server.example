# إعدادات السيرفر — يُنشأ تلقائياً عند التنصيب (INSTALL.bat)

# مفتاح سري (يُولَّد تلقائياً عند أول تنصيب)
SECRET_KEY=change-me-to-a-long-random-string

# منفذ الويب (افتراضي 8005)
PORT=8005

# الاستماع على كل الواجهات — ضروري لـ LAN / Wi-Fi
HOST=0.0.0.0

# وضع التنصيب: البيانات في %LOCALAPPDATA%\LF_TrainingEvaluation
LF_INSTALL_MODE=1

# إنتاج: بدون وضع تصحيح Flask
FLASK_DEBUG=0

# فتح المتصفح على السيرفر عند التشغيل (0 لتعطيل)
LF_OPEN_BROWSER=1

# خيوط Waitress — زِدها عند كثرة الأجهزة المتصلة (LAN/Wi-Fi)
WAITRESS_THREADS=16
WAITRESS_CHANNEL_TIMEOUT=120
WAITRESS_CONNECTION_LIMIT=200

# سرعة التحديث التلقائي بين السيرفر والعملاء (milliseconds)
# صفحات المتابعة (سيطرة، مهام، تقييم): LF_HEARTBEAT_FAST_POLL_MS
# باقي الصفحات: LF_HEARTBEAT_POLL_MS
LF_HEARTBEAT_POLL_MS=2000
LF_HEARTBEAT_FAST_POLL_MS=1000

# اختياري: مجلد بيانات مخصص بدل LOCALAPPDATA
# LF_DATA_DIR=D:\LF_Data
